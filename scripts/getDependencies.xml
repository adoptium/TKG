<project name="getDependency" default="getDependentLibs" basedir="."
	xmlns:if="ant:if"
	xmlns:unless="ant:unless">
	<description>
		Get Third Party Dependencies
	</description>

	<target name="getJtregVersion">
		<!--
		# Versions 11, 17, 21, 25 on z/OS need to use jtreg_8_2 which uses defaultCharset() to parse TEST.group files.
		-->
		<condition property="jtregTar" value="jtreg_8_2">
			<and>
				<contains string="${SPEC}" substring="zos"/>
				<matches pattern="^(11|17|21|25)$" string="${JDK_VERSION}"/>
			</and>
		</condition>
		<!-- versions 8-10, 12-16 -->
		<condition property="jtregTar" value="jtreg_5_1_b01">
			<matches pattern="^([89]|1[02-6])$" string="${JDK_VERSION}"/>
		</condition>
		<!-- versions 11, 18-20, 22-23 -->
		<condition property="jtregTar" value="jtreg_7_3_1_1">
			<matches pattern="^(11|1[89]|2[023])$" string="${JDK_VERSION}"/>
		</condition>
		<!-- versions 17, 21 -->
		<condition property="jtregTar" value="jtreg_7_5_2_1">
			<matches pattern="^(17|21)$" string="${JDK_VERSION}"/>
		</condition>
		<!-- version 24 -->
		<condition property="jtregTar" value="jtreg_7_4_1">
			<matches pattern="^24$" string="${JDK_VERSION}"/>
		</condition>
		<!-- version 25 -->
		<condition property="jtregTar" value="jtreg_8_2">
			<matches pattern="^25$" string="${JDK_VERSION}"/>
		</condition>
		<!-- version 26 -->
		<condition property="jtregTar" value="jtreg_8_1_1">
			<matches pattern="^26$" string="${JDK_VERSION}"/>
		</condition>
		<!-- version 27 -->
		<condition property="jtregTar" value="jtreg_8_2_1_1">
			<matches pattern="^27$" string="${JDK_VERSION}"/>
		</condition>
		<!-- versions 28+ (default) -->
		<property name="jtregTar" value="jtreg_8_3_1"/>

		<echo message="jtreg version used is : ${jtregTar}"/>

		<condition property="openj9jtregtimeouthandler" value=",tohandler_simple">
			<or>
				<equals arg1="${JDK_IMPL}" arg2="ibm"/>
				<equals arg1="${JDK_IMPL}" arg2="openj9"/>
			</or>
		</condition>
		<property name="openj9jtregtimeouthandler" value=""/>

		<property name="LIB" value="${jtregTar}${openj9jtregtimeouthandler}"/>
	</target>

	<target name="getJtreg" depends="getJtregVersion,getDependentLibs">
		<mkdir dir="${DEST}"/>
		<condition property="jtreg.in.libdir">
			<available file="${LIB_DIR}/${jtregTar}.tar.gz"/>
		</condition>
		<condition property="jtreg.is.custom">
			<and>
				<not><isset property="jtreg.in.libdir"/></not>
				<available file="custom_jtreg.tar.gz"/>
			</and>
		</condition>
		<copy file="${LIB_DIR}/${jtregTar}.tar.gz" tofile="${jtregTar}.tar.gz" if:set="jtreg.in.libdir"/>
		<echo message="Using custom_jtreg.tar.gz" if:set="jtreg.is.custom"/>
		<copy file="custom_jtreg.tar.gz" tofile="${jtregTar}.tar.gz" if:set="jtreg.is.custom"/>
		<exec executable="gzip" failonerror="true">
			<arg line="-df ${jtregTar}.tar.gz"/>
		</exec>
		<condition property="is.zos">
			<contains string="${SPEC}" substring="zos"/>
		</condition>
		<exec executable="tar" failonerror="true" if:set="is.zos">
			<arg line="xfo ${jtregTar}.tar -C ${DEST}"/>
		</exec>
		<exec executable="sh" failonerror="true" unless:set="is.zos">
			<arg line="-c 'cat ${jtregTar}.tar | (cd ${DEST} &amp;&amp; tar xof -)'"/>
		</exec>
	</target>

	<target name="getDependentLibs" unless="skipDependency">
		<!-- default LIB to all if not set by getJtregVersion or caller -->
		<property name="LIB" value="all"/>
		<exec executable="perl" failonerror="true">
			<arg line="${TEST_ROOT}/TKG/scripts/getDependencies.pl -path ${LIB_DIR} -task default -dependencyList ${LIB}"/>
		</exec>
	</target>
</project>
